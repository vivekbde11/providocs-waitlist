# Copy this file to `.env.local` and fill in your values.
# When deploying, also add these in: Vercel → Project → Settings → Environment Variables
# (or Netlify → Site settings → Environment variables).

# Brevo Send-Email API key.
# Get one at: https://app.brevo.com/settings/keys/api  →  "Generate a new API key"
BREVO_API_KEY=

# Verified sender email in Brevo (Brevo → Senders, Domains & Dedicated IPs → Senders).
# Must be a sender you've verified, otherwise Brevo rejects the request.
BREVO_FROM_EMAIL=
BREVO_FROM_NAME=Providocs Waitlist

# Where waitlist notifications should be delivered.
BREVO_TO_EMAIL=support@providocs.com
BREVO_TO_NAME=Providocs Team

# Optional — Brevo contacts list ID to upsert leads into (skip if not used).
# Find the list ID at: Brevo → Contacts → Lists → click your list → URL has /list/{id}
BREVO_LIST_ID=
